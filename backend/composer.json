{
    "name": "theujnh/movie_rental",
    "scripts": {
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "php -S localhost:8000 -t public"
        ],
        "fix": "php-cs-fixer fix",
        "analyse": "phpstan analyse",
        "test": "phpunit"
    },
    "require": {
        "slim/slim": "^4.15",
        "php-di/php-di": "^7.1",
        "vlucas/phpdotenv": "^5.6",
        "monolog/monolog": "^3.10",
        "slim/http": "^1.4",
        "slim/psr7": "^1.8"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "authors": [
        {
            "name": "Matheus Santos",
            "email": "matheusjnh@gmail.com"
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^12.5",
        "phpstan/phpstan": "^2.2",
        "friendsofphp/php-cs-fixer": "^3.95"
    }
}
